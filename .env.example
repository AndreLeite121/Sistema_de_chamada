# ============================================================
# Sistema de Frequência por QR Code — Configuração de ambiente
# Copie este arquivo para `.env` e ajuste os valores.
# ============================================================

# --- Django ---
SECRET_KEY=troque-por-uma-chave-aleatoria-de-50-caracteres
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Banco de dados ---
# Padrão: sqlite3 (zero configuração, recomendado para dev/avaliação).
# Se quiser usar PostgreSQL, troque DB_ENGINE para `postgresql` e
# descomente o bloco abaixo.
DB_ENGINE=sqlite3

# --- PostgreSQL (opcional) ---
# DB_ENGINE=postgresql
# DB_NAME=sistema_freq
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432

# --- URL base usada na geração de QR Codes ---
SITE_URL=http://localhost:8000

# --- Rede institucional (CIDRs separados por vírgula) ---
# Preencha com os ranges de IP da universidade. Em dev, adicione também
# 127.0.0.0/8 e ::1/128 para permitir acesso via localhost.
UNIVERSITY_IP_RANGES=
